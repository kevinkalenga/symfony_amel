{% extends 'base.html.twig' %}



{% block body %}
  <div class="container my-5">
     <h1>{{category.name}}</h1>
     <p>Cette categorie contient {{category.products|length}} produit(s).</p>

     <div class="row">
        {% for product in category.products %}
            <div class="col-md-3 text-center">
               <img src="/uploads/{{product.illustration}}" class="img-fluid" alt="" />
               <strong>{{product.name}}</strong>
               <strong>{{product.getPriceWithTaxe}}</strong>
            </div>

        {% endfor %}
     </div>
  </div>
{% endblock %}
