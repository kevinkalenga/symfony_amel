{% extends 'base.html.twig' %}



{% block body %}


   <div class="container my-5">
      <h1>Espace membre</h1>
      <div class="row">
         <div class="col-md-3">
             {% include 'account/_menu.html.twig' %}
         </div>
         <div class="col-md-9">
             <h5>Mes adresses</h5>
             <a href="{{path('app_account_address_form')}}" class="btn btn-light">Ajoutr une adresse</a>
         </div>

         {% if app.user.addresses|length == 0 %}

           <p>Vous n'avez pas encore d'adresse enregistré sur le site.</p>

         {% else %}
            {% for address in app.user.addresses %}
              <div class="row">
               <div class="bg-light p-2 text-center mt-3">
                  <strong>{{address.firstname}}</strong><br>
                  <strong>{{address.lastname}}</strong><br>
                  <strong>{{address.address}}</strong><br>
                  <strong>{{address.postal}}</strong><br>
                  <strong>{{address.city}}</strong><br>
                  <strong>{{address.country}}</strong><br>
                  <strong>{{address.phone}}</strong><br>
                  <a href="{{path('app_account_address_form', {id:address.id})}}" class="small text-secondary">Editer</a>
                  <a href="{{path('app_account_address_delete', {id:address.id})}}" class="small text-secondary">Supprimer</a>
                 
               </div>
              </div>
            {% endfor %}
         {% endif %}
        
        
       
      </div>
   </div>



{% endblock %}