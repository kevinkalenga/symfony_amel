
{% extends "base.html.twig" %}

{% block body %}
   <div class="my-5 container">
         <h1 class="text-center">Mon panier</h1>
        <div class="row"> 
           <div class="col-md-8">
           
               {% for product in cart %}
                 <div class="row mt-2">
                    <div class="col-md-2">
                    {# object venant de la method add de Cart.php #}
                       <img src="/uploads/{{product.object.illustration}}" class="img-fluid" alt="{{product.object.name}}" /> 
                    </div>
                    <div class="col-md-6">
                       <strong>{{product.object.name}}</strong>
                       <span class="d-block small">Prix :
								{{ product.object.getPriceWithTaxe|price}}</span>
                    </div>
                    <div class="col-md-2 text-right">
                        <a href="{{path('app_cart_decrease', {id:product.object.id})}}">-</a>
                        <span class="badge text-bg-secondary">x{{product.qty}}</span>
                        <a href="{{path('app_cart_add', {id:product.object.id})}}">+</a>
                    </div>
                    {# <div class="col-md-2 text-right">
                       <span class="badge text-bg-secondary">x{{product.qty}}</span>
                    </div> #}
                    <div class="col-md-2">
                       <strong>x{{(product.qty * product.object.getPriceWithTaxe)|price}}</strong>
                    </div>
                 
                 </div>


              {% endfor %} 
              <a class="small mt-3 d-block" href="{{path('app_cart_remove')}}">Vider le panier</a>
           </div>
           <div class="col-md-4">
              <div class="bg-light p-3 shadow-sm">
                 <div class="d-flex justify-content-between">
                   <span class="fw-bold">Total Produit</span>
                   <span>{{fullCartQuantity}}</span>
                 </div>
                 <div class="d-flex justify-content-between mt-3">
                   <span class="fw-bold">Prix Total T.T.C</span>
                    <span>{{totalPrice|price}}</span>
                 </div>
              </div>
              <a href="#" class="btn btn-success w-100">Commander</a>
           </div>
           
         </div>
     
   </div>
{% endblock %}
